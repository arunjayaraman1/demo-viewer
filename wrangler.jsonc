{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "demo-viewer",
  "compatibility_date": "2026-07-16",
  "observability": {
    "enabled": true
  },
  "main": ".vercel/output/static/_worker.js/index.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".vercel/output/static"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "demo-portal-db",
      "database_id": "bfd0d7b2-ec90-41ab-85cf-255d8f63ab8f"
    }
  ]
}
