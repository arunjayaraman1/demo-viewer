{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "demo-viewer",
  "compatibility_date": "2026-07-16",
  "pages_build_output_dir": ".vercel/output/static",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "demo-viewer",
      "database_id": "1d7b5f94-5802-4b0d-b3b5-a8509b6683c3"
    }
  ]
}
